# ==============================================================================
# ATTY Financial - Production Environment Variables
# ==============================================================================
# Copy this file to .env.production and fill in actual values.
# DO NOT commit .env.production to version control.
#
# Environment: Production
# Mode: production
# ==============================================================================

# ==============================================================================
# APPLICATION
# ==============================================================================
NODE_ENV=production
VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0

# ==============================================================================
# FIREBASE PRODUCTION CONFIGURATION
# ==============================================================================
# Firebase project configuration for production
# Get your config from: https://console.firebase.google.com/
# Navigate to: Project Settings > General > Your Apps > Web App > Config

# Firebase Web App Configuration (Client-side)
VITE_FIREBASE_API_KEY=your_production_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=atty-financial-production.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=atty-financial-production
VITE_FIREBASE_STORAGE_BUCKET=atty-financial-production.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Emulator (DISABLED in production)
VITE_FIREBASE_USE_EMULATOR=false

# ==============================================================================
# BANKJOY API PRODUCTION CONFIGURATION
# ==============================================================================
# BankJoy API configuration for production
# Get your API credentials from: https://api.bankjoy.com/portal

# BankJoy API Configuration (Client-side - Read Only Access)
VITE_BANKJOY_API_URL=https://api.bankjoy.com/v1
VITE_BANKJOY_API_KEY=your_production_bankjoy_api_key
VITE_BANKJOY_API_TIMEOUT=30000
VITE_BANKJOY_MAX_RETRIES=3
VITE_BANKJOY_RATE_LIMIT_ENABLED=true

# BankJoy Webhook Configuration (Server-side)
# These are used in Firebase Cloud Functions
BANKJOY_WEBHOOK_SECRET=your_webhook_secret_for_signature_verification
BANKJOY_WEBHOOK_ENDPOINT=/api/webhooks/bankjoy

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Feature flags to enable/disable features in production
# Default: true for production features, false for beta features

VITE_FEATURE_BANK_INTEGRATION_ENABLED=true
VITE_FEATURE_AUTO_ALLOCATE_ENABLED=true
VITE_FEATURE_EMAIL_NOTIFICATIONS_ENABLED=true
VITE_FEATURE_SSO_ENABLED=true
VITE_FEATURE_MULTI_TENANT_ENABLED=true
VITE_FEATURE_ADVANCED_REPORTING_ENABLED=true
VITE_FEATURE_API_ACCESS_ENABLED=true
VITE_FEATURE_WEBHOOKS_ENABLED=true
VITE_FEATURE_BULK_IMPORT_ENABLED=true
VITE_FEATURE_CUSTOM_FIELDS_ENABLED=true

# Beta Features (default false in production)
VITE_FEATURE_AI_INSIGHTS_ENABLED=false
VITE_FEATURE_PREDICTIVE_ANALYTICS_ENABLED=false

# ==============================================================================
# ANALYTICS CONFIGURATION
# ==============================================================================
# Firebase Analytics
VITE_FIREBASE_ANALYTICS_ENABLED=true

# Additional Analytics Providers (Optional)
# Google Analytics 4
VITE_GA4_MEASUREMENT_ID=your_ga4_measurement_id

# Segment Analytics (Optional)
VITE_SEGMENT_WRITE_KEY=your_segment_write_key

# Mixpanel Analytics (Optional)
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# ==============================================================================
# API ENDPOINTS
# ==============================================================================
# Production API endpoints
VITE_API_URL=https://api.attyfinancial.com/api/v1
VITE_API_TIMEOUT=30000

# ==============================================================================
# SECURITY
# ==============================================================================
# Security settings
VITE_CSP_ENABLED=true
VITE_X_FRAME_OPTIONS=DENY
VITE_CONTENT_SECURITY_POLICY=upgrade-insecure-requests

# ==============================================================================
# PERFORMANCE
# ==============================================================================
# Performance optimization settings
VITE_ENABLE_SERVICE_WORKER=true
VITE_CACHE_STRATEGY=network-first
VITE_OFFLINE_ENABLED=true

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================
# Error tracking and monitoring
VITE_SENTRY_DSN=your_sentry_dsn
VITE_SENTRY_ENVIRONMENT=production
VITE_LOG_LEVEL=error

# ==============================================================================
# RATE LIMITING
# ==============================================================================
# Rate limiting configuration
VITE_RATE_LIMIT_ENABLED=true
VITE_RATE_LIMIT_MAX_REQUESTS=100
VITE_RATE_LIMIT_WINDOW_MS=60000

# ==============================================================================
# CONTENT DELIVERY
# ==============================================================================
# CDN Configuration (Optional)
VITE_CDN_URL=https://cdn.attyfinancial.com
VITE_ASSET_VERSION=1.0.0

# ==============================================================================
# MAINTENANCE & SUPPORT
# ==============================================================================
# Support information
VITE_SUPPORT_EMAIL=support@attyfinancial.com
VITE_SUPPORT_PHONE=+1-800-ATTY-FIN
VITE_DOCS_URL=https://docs.attyfinancial.com
VITE_STATUS_PAGE_URL=https://status.attyfinancial.com

# ==============================================================================
# THIRD-PARTY INTEGRATIONS (Optional)
# ==============================================================================
# Stripe Payments (if enabled)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# WorkOS SSO (if enabled)
VITE_WORKOS_CLIENT_ID=client_your_workos_client_id

# Slack Integration (if enabled)
VITE_SLACK_CLIENT_ID=your_slack_client_id

# ==============================================================================
# LEGAL & COMPLIANCE
# ==============================================================================
# Terms and Privacy Policy URLs
VITE_TERMS_URL=https://attyfinancial.com/terms
VITE_PRIVACY_URL=https://attyfinancial.com/privacy
VITE_COOKIE_POLICY_URL=https://attyfinancial.com/cookies

# ==============================================================================
# DEVELOPMENT & DEBUGGING (DISABLED IN PRODUCTION)
# ==============================================================================
VITE_DEBUG_MODE=false
VITE_DEVTOOLS=false
VITE_VERBOSE_LOGGING=false

# ==============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ==============================================================================
# These override default values for production environment
VITE_DEFAULT_PAGE_SIZE=25
VITE_DATE_FORMAT=MMMM d, yyyy
VITE_CURRENCY_FORMAT=USD
VITE_TIMEZONE=America/New_York
