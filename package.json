{
  "name": "atty-financial",
  "version": "0.1.0",
  "private": true,
  "description": "Credit line platform for law offices specializing in personal injury and tort law",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx,ts,tsx",
    "format": "prettier --write .",
    "test": "jest --silent",
    "test:watch": "jest --watch --silent",
    "test:coverage": "jest --coverage --silent",
    "test:ci": "jest --ci --silent --coverage",
    "test:ui": "jest --watch --silent",
    "test:unit": "jest --testPathPattern='src/(services|store)/__tests__/' --silent",
    "test:integration": "jest --testPathPattern='src/__tests__/integration/' --silent",
    "test:components": "jest --testPathPattern='src/components/.*?/__tests__/' --silent",
    "test:firebase": "tsx scripts/test-firebase.ts",
    "test:firebase:quick": "tsx scripts/test-firebase.ts --quick",
    "verify:brand": "tsx scripts/verify-brand-tokens.ts",
    "verify:brand:fix": "tsx scripts/verify-brand-tokens.ts --fix",
    "verify:brand:report": "tsx scripts/verify-brand-tokens.ts --report brand-report.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "firebase": "^12.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "glob": "^11.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.4.2",
    "vite": "^5.2.0"
  }
}
