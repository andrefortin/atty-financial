# ==============================================================================
# ATTY Financial - Staging Environment Variables
# ==============================================================================
# Copy this file to .env.staging and fill in actual values.
# DO NOT commit .env.staging to version control.
#
# Environment: Staging
# Mode: development (for debugging) or production (for pre-release testing)
# ==============================================================================

# ==============================================================================
# APPLICATION
# ==============================================================================
NODE_ENV=development
VITE_APP_ENV=staging
VITE_APP_VERSION=1.0.0-staging

# ==============================================================================
# FIREBASE STAGING CONFIGURATION
# ==============================================================================
# Firebase project configuration for staging/testing
# Create a separate Firebase project for staging
# Get your config from: https://console.firebase.google.com/
# Navigate to: Project Settings > General > Your Apps > Web App > Config

# Firebase Web App Configuration (Client-side)
VITE_FIREBASE_API_KEY=your_staging_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=atty-financial-staging.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=atty-financial-staging
VITE_FIREBASE_STORAGE_BUCKET=atty-financial-staging.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_staging_messaging_sender_id
VITE_FIREBASE_APP_ID=your_staging_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_staging_measurement_id

# Firebase Emulator (Optional for local testing)
VITE_FIREBASE_USE_EMULATOR=false

# ==============================================================================
# BANKJOY API STAGING CONFIGURATION
# ==============================================================================
# BankJoy API configuration for staging
# Use staging/test environment if available, or sandbox mode

# BankJoy API Configuration (Client-side - Read Only Access)
VITE_BANKJOY_API_URL=https://api-staging.bankjoy.com/v1
VITE_BANKJOY_API_KEY=your_staging_bankjoy_api_key
VITE_BANKJOY_API_TIMEOUT=30000
VITE_BANKJOY_MAX_RETRIES=3
VITE_BANKJOY_RATE_LIMIT_ENABLED=true

# BankJoy Webhook Configuration (Server-side)
BANKJOY_WEBHOOK_SECRET=your_staging_webhook_secret_for_signature_verification
BANKJOY_WEBHOOK_ENDPOINT=/api/webhooks/bankjoy

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Feature flags to enable/disable features in staging
# Enable beta features for testing in staging

VITE_FEATURE_BANK_INTEGRATION_ENABLED=true
VITE_FEATURE_AUTO_ALLOCATE_ENABLED=true
VITE_FEATURE_EMAIL_NOTIFICATIONS_ENABLED=true
VITE_FEATURE_SSO_ENABLED=true
VITE_FEATURE_MULTI_TENANT_ENABLED=true
VITE_FEATURE_ADVANCED_REPORTING_ENABLED=true
VITE_FEATURE_API_ACCESS_ENABLED=true
VITE_FEATURE_WEBHOOKS_ENABLED=true
VITE_FEATURE_BULK_IMPORT_ENABLED=true
VITE_FEATURE_CUSTOM_FIELDS_ENABLED=true

# Beta Features (enabled in staging for testing)
VITE_FEATURE_AI_INSIGHTS_ENABLED=true
VITE_FEATURE_PREDICTIVE_ANALYTICS_ENABLED=true

# ==============================================================================
# ANALYTICS CONFIGURATION
# ==============================================================================
# Firebase Analytics
VITE_FIREBASE_ANALYTICS_ENABLED=true

# Additional Analytics Providers (Optional - Use staging keys)
# Google Analytics 4
VITE_GA4_MEASUREMENT_ID=your_staging_ga4_measurement_id

# Segment Analytics (Optional)
VITE_SEGMENT_WRITE_KEY=your_staging_segment_write_key

# Mixpanel Analytics (Optional)
VITE_MIXPANEL_TOKEN=your_staging_mixpanel_token

# ==============================================================================
# API ENDPOINTS
# ==============================================================================
# Staging API endpoints
VITE_API_URL=https://staging-api.attyfinancial.com/api/v1
VITE_API_TIMEOUT=30000

# ==============================================================================
# SECURITY
# ==============================================================================
# Security settings (relaxed for staging testing)
VITE_CSP_ENABLED=true
VITE_X_FRAME_OPTIONS=SAMEORIGIN
VITE_CONTENT_SECURITY_POLICY=upgrade-insecure-requests

# ==============================================================================
# PERFORMANCE
# ==============================================================================
# Performance optimization settings
VITE_ENABLE_SERVICE_WORKER=true
VITE_CACHE_STRATEGY=stale-while-revalidate
VITE_OFFLINE_ENABLED=true

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================
# Error tracking and monitoring (use staging project)
VITE_SENTRY_DSN=your_staging_sentry_dsn
VITE_SENTRY_ENVIRONMENT=staging
VITE_LOG_LEVEL=debug

# ==============================================================================
# RATE LIMITING
# ==============================================================================
# Rate limiting configuration (more lenient in staging)
VITE_RATE_LIMIT_ENABLED=true
VITE_RATE_LIMIT_MAX_REQUESTS=200
VITE_RATE_LIMIT_WINDOW_MS=60000

# ==============================================================================
# CONTENT DELIVERY
# ==============================================================================
# CDN Configuration (Optional - use staging CDN)
VITE_CDN_URL=https://staging-cdn.attyfinancial.com
VITE_ASSET_VERSION=1.0.0-staging

# ==============================================================================
# MAINTENANCE & SUPPORT
# ==============================================================================
# Support information
VITE_SUPPORT_EMAIL=support@attyfinancial.com
VITE_SUPPORT_PHONE=+1-800-ATTY-FIN
VITE_DOCS_URL=https://docs-staging.attyfinancial.com
VITE_STATUS_PAGE_URL=https://status-staging.attyfinancial.com

# ==============================================================================
# THIRD-PARTY INTEGRATIONS (Optional)
# ==============================================================================
# Stripe Payments (use test keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# WorkOS SSO (use staging keys)
VITE_WORKOS_CLIENT_ID=client_your_staging_workos_client_id

# Slack Integration (use test app)
VITE_SLACK_CLIENT_ID=your_staging_slack_client_id

# ==============================================================================
# LEGAL & COMPLIANCE
# ==============================================================================
# Terms and Privacy Policy URLs
VITE_TERMS_URL=https://staging.attyfinancial.com/terms
VITE_PRIVACY_URL=https://staging.attyfinancial.com/privacy
VITE_COOKIE_POLICY_URL=https://staging.attyfinancial.com/cookies

# ==============================================================================
# DEVELOPMENT & DEBUGGING (ENABLED IN STAGING)
# ==============================================================================
VITE_DEBUG_MODE=true
VITE_DEVTOOLS=true
VITE_VERBOSE_LOGGING=true

# ==============================================================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ==============================================================================
# These override default values for staging environment
VITE_DEFAULT_PAGE_SIZE=10
VITE_DATE_FORMAT=MMMM d, yyyy
VITE_CURRENCY_FORMAT=USD
VITE_TIMEZONE=America/New_York

# ==============================================================================
# STAGING-SPECIFIC SETTINGS
# ==============================================================================
# Test data settings
VITE_USE_TEST_DATA=false
VITE_MOCK_BANKJOY=false
VITE_MOCK_FIREBASE=false
VITE_MOCK_AUTHENTICATION=false

# Feature testing
VITE_ENABLE_FEATURE_TESTING=true
VITE_TEST_USER_EMAIL=test@attyfinancial.com
