  updatedAt: number;
};

/**
 * Data Retention Policy collection type
 */
export type FirestoreDataRetentionPolicy = {
  policyId: string;
  policyType: 'audit-logs' | 'transactions' | 'matters' | 'allocations' | 'bank-feeds';
  firmId: string;
  name: string;
  retentionPeriodDays: number;
  startDate: string;
  endDate: string;
  active: boolean;
  description: string;
  dataCategories: string[];
  legalRequirements: string[];
  deletionPolicy: 'auto-delete' | 'manual-review' | 'retain-forever';
  deletionDelayDays: number;
  complianceNotes?: string;
  createdAt: number;
  updatedAt: number;
};

