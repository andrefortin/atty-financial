/**
 * Compliance Report collection type
 */
export type FirestoreComplianceReport = {
  reportId: string;
  reportType: 'SOC2' | 'SOC1' | 'HIPAA' | 'GDPR' | 'PCI-DSS' | 'internal';
  firmId: string;
  periodStart: string;
  periodEnd: string;
  status: 'draft' | 'in-review' | 'completed' | 'published';
  title: string;
  description: string;
  sections: ComplianceReportSection[];
  summary: string;
  findings: string[];
  recommendations: string[];
  riskLevel: 'low' | 'medium' | 'high' | 'critical';
  complianceScore: number;
  auditLogIds: string[];
  createdBy: string;
  reviewedBy?: string;
  reviewedAt?: number;
  approvedAt?: number;
  publishedAt?: number;
  notes?: string;
  createdAt: number;
  updatedAt: number;
};

