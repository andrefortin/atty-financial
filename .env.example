# ==============================================================================
# PropFlow Monorepo Environment Variables Reference
# ==============================================================================
# This file documents all environment variables used across the monorepo.
# Copy relevant sections to individual app .env files for local development.
#
# Framework-specific prefixes:
#   - VITE_*      : Variables exposed to Vite apps (frontend, plugin)
#   - NEXT_PUBLIC_*: Variables exposed to Next.js apps (landing)
#   - (no prefix) : Server-side only variables (backend)
#
# See: https://vitejs.dev/guide/env-and-mode.html
# See: https://nextjs.org/docs/basic-features/environment-variables
# ==============================================================================

# ==============================================================================
# SHARED VARIABLES (used by multiple apps)
# ==============================================================================

# Convex Backend-as-a-Service
# Real-time database and backend functions
# Get your deployment URL from: https://dashboard.convex.dev
CONVEX_DEPLOYMENT=your-deployment-name
CONVEX_URL=https://your-deployment-name.convex.cloud
CONVEX_DEPLOYMENT_URL=https://your-deployment-name.convex.cloud
VITE_CONVEX_URL=https://your-deployment-name.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# PostHog Analytics
# Product analytics and user behavior tracking
# Get your project key from: https://app.posthog.com
POSTHOG_PROJECT_KEY=your_posthog_project_key
POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_KEY=your_posthog_project_key
VITE_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key

# ==============================================================================
# BACKEND (apps/backend)
# ==============================================================================

# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Corporate LLM (GLM-4)
# Corporate account for AI-powered listing descriptions
# See: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_MODEL=glm-4
GLM_MAX_TOKENS=4000
GLM_TEMPERATURE=0.7

# Alternative GLM-4 key (used in ai.service.ts)
GLM4_API_KEY=your-glm4-api-key

# OpenAI (optional user-provided keys)
# Users can bring their own OpenAI API key for premium AI features
# See: https://platform.openai.com/
OPENAI_API_KEY=sk-openai-your-key
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude (optional)
# Users can bring their own Anthropic API key for premium AI features
# See: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Stripe Payments
# Payment processing for subscription tiers
# See: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_tier_id
STRIPE_AGENCY_PRICE_ID=price_your_agency_tier_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_tier_id

# WorkOS SSO
# Single sign-on integration for enterprise customers
# See: https://dashboard.workos.com/
WORKOS_API_KEY=sk_workos_your_api_key
WORKOS_CLIENT_ID=client_your_client_id
WORKOS_REDIRECT_URI=http://localhost:3000/auth/workos/callback
WORKOS_SECRET_KEY=your_workos_secret_key

# Slack Integration
# Slack bot for team notifications and updates
# See: https://api.slack.com/apps
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Firebase Push Notifications
# Push notification service for mobile and desktop
# See: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Facebook Integration
# Facebook Marketplace integration for conversation webhooks
# See: https://developers.facebook.com/
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your_verify_token

# SaaSMODE Integration
# Third-party service integration
# See: https://saasmode.com/
SAASMODE_API_URL=https://saasmode.com/api
SAASMODE_API_KEY=your_saasmode_api_key

# CORS Settings
# Allowed origins for cross-origin requests
FRONTEND_URL=http://localhost:5173
LANDING_URL=http://localhost:3000

# Rate Limiting
# Rate limit configuration for API endpoints
RATE_LIMIT_SHORT=10
RATE_LIMIT_MINUTE=100
RATE_LIMIT_HOUR=1000

# Subscription Limits
# Usage limits per subscription tier
FREE_SCRAPES_LIMIT=100
FREE_POSTS_LIMIT=5
PRO_SCRAPES_LIMIT=1500
PRO_POSTS_LIMIT=500
AGENCY_TEAM_LIMIT=25

# ==============================================================================
# FRONTEND (apps/frontend - Vite)
# ==============================================================================
# Vite automatically loads variables prefixed with VITE_ into the client bundle.
# See: https://vitejs.dev/guide/env-and-mode.html

# Convex Backend-as-a-Service
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# PostHog Analytics
VITE_POSTHOG_KEY=your_posthog_project_key
VITE_POSTHOG_HOST=https://app.posthog.com

# Firebase Authentication & Database
# Firebase client SDK configuration
# Get your config from: https://console.firebase.google.com/
# Navigate to: Project Settings > General > Your Apps > Web App > Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# API Endpoints
VITE_API_URL=http://localhost:3001/api

# ==============================================================================
# LANDING (apps/landing - Next.js)
# ==============================================================================
# Next.js built-in environment variables
# See: https://nextjs.org/docs/basic-features/environment-variables

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Convex Backend-as-a-Service
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key

# Dashboard URL (for redirects)
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:5173

# ==============================================================================
# PLUGIN (apps/plugin - Chrome Extension)
# ==============================================================================
# Vite automatically loads variables prefixed with VITE_ into the client bundle.
# See: https://vitejs.dev/guide/env-and-mode.html

# API Endpoints
VITE_PLUGIN_API_URL=http://localhost:3001/api

# Convex Backend-as-a-Service
VITE_PLUGIN_CONVEX_URL=https://your-deployment.convex.cloud

# ==============================================================================
# CONVEX (convex/)
# ==============================================================================
# Convex function environment variables
# These are set in the Convex dashboard or via convex deploy
# See: https://dashboard.convex.dev

CONVEX_DEPLOYMENT=your-deployment-name
